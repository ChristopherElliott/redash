# Required
REDASH_COOKIE_SECRET=your-secret-key-here

# Database
REDASH_DATABASE_URL=postgresql://localhost/redash

# Redis
REDASH_REDIS_URL=redis://localhost:6379/0

# Server
PORT=5000
BIND_ADDRESS=0.0.0.0
REDASH_HOST=http://localhost:5000

# Mail (optional)
# REDASH_MAIL_SERVER=smtp.example.com
# REDASH_MAIL_PORT=587
# REDASH_MAIL_USE_TLS=true
# REDASH_MAIL_USERNAME=user@example.com
# REDASH_MAIL_PASSWORD=secret
# REDASH_MAIL_DEFAULT_SENDER=redash@example.com

# Google OAuth (optional)
# REDASH_GOOGLE_CLIENT_ID=
# REDASH_GOOGLE_CLIENT_SECRET=

# LDAP (optional)
# REDASH_LDAP_LOGIN_ENABLED=false
# REDASH_LDAP_URL=ldap://ldap.example.com:389

# Security
REDASH_ENFORCE_HTTPS=false
REDASH_COOKIES_SECURE=false

# Logging
REDASH_LOG_LEVEL=INFO
REDASH_LOG_STDOUT=true

# Sentry (optional)
# REDASH_SENTRY_DSN=
